# Flashly combined production environment template.
# Copy into your deployment provider or split values into the backend/app templates below.
# Do not commit real secrets.

# App public env
EXPO_PUBLIC_USE_BACKEND=true
EXPO_PUBLIC_FLASHLY_AUTH_MODE=clerk
EXPO_PUBLIC_FLASHLY_API_BASE_URL=https://your-flashly-backend.example
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me
EXPO_PUBLIC_POSTHOG_KEY=phc_replace_me
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
EXPO_PUBLIC_SENTRY_DSN=

# Backend server env
NODE_ENV=production
PORT=8081
FLASHLY_DATA_MODE=database
FLASHLY_STORAGE_MODE=cloud
FLASHLY_STORAGE_PROVIDER=s3
FLASHLY_EXTRACTION_MODE=external
FLASHLY_GENERATION_MODE=external
FLASHLY_AI_PROVIDER=nvidia
FLASHLY_OCR_PROVIDER=ocrspace
FLASHLY_BILLING_MODE=revenuecat

# Database
DATABASE_URL=
DATABASE_CA_CERT=
DATABASE_CA_CERT_BASE64=

# Storage: Cloudflare R2 or S3-compatible bucket
FLASHLY_S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
FLASHLY_S3_REGION=auto
FLASHLY_S3_BUCKET=flashly-production-uploads
FLASHLY_S3_ACCESS_KEY_ID=
FLASHLY_S3_SECRET_ACCESS_KEY=
FLASHLY_S3_PUBLIC_BASE_URL=
FLASHLY_S3_FORCE_PATH_STYLE=true

# Clerk
CLERK_SECRET_KEY=

# NVIDIA AI
FLASHLY_AI_API_KEY=
FLASHLY_AI_MODEL=openai/gpt-oss-20b
FLASHLY_AI_BASE_URL=https://integrate.api.nvidia.com/v1

# OCR.space
FLASHLY_OCR_API_KEY=
FLASHLY_OCR_API_URL=https://api.ocr.space/parse/image
FLASHLY_OCR_TIMEOUT_MS=20000
FLASHLY_PDF_EXTRACTION_PROVIDER=local

# RevenueCat
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_PROJECT_ID=
REVENUECAT_API_KEY=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=flashly@1.0.0

# Security and rate limits
FLASHLY_ALLOWED_ORIGINS=https://your-app.example
FLASHLY_RATE_LIMIT_WINDOW_MS=60000
FLASHLY_RATE_LIMIT_MAX=120
FLASHLY_AUTH_RATE_LIMIT_MAX=30
FLASHLY_UPLOAD_RATE_LIMIT_MAX=30
FLASHLY_GENERATION_RATE_LIMIT_MAX=20
FLASHLY_SERVER_MAX_BODY_BYTES=83886080
