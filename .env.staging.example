# Flashly staging environment template.
# Do not commit real secrets. Use the repository's existing variable names.

# Runtime
NODE_ENV=production
PORT=8081
FLASHLY_ENV=staging
FLASHLY_SERVER_MAX_BODY_BYTES=83886080

# Public application configuration
EXPO_PUBLIC_FLASHLY_API_BASE_URL=https://staging-api.example.com
EXPO_PUBLIC_FLASHLY_AUTH_MODE=clerk
EXPO_PUBLIC_USE_BACKEND=true

# Database
FLASHLY_DATA_MODE=database
DATABASE_URL=
# Required for managed PostgreSQL providers such as Aiven.
# Store either the PEM with escaped newlines or the base64-encoded PEM in Railway.
DATABASE_CA_CERT=
DATABASE_CA_CERT_BASE64=

# Storage
FLASHLY_STORAGE_MODE=cloud
FLASHLY_STORAGE_PROVIDER=s3
FLASHLY_S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
FLASHLY_S3_REGION=auto
FLASHLY_S3_BUCKET=flashly-staging-uploads
FLASHLY_S3_ACCESS_KEY_ID=
FLASHLY_S3_SECRET_ACCESS_KEY=
FLASHLY_S3_PUBLIC_BASE_URL=
FLASHLY_S3_FORCE_PATH_STYLE=true

# Clerk
CLERK_SECRET_KEY=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_key

# OCR
FLASHLY_EXTRACTION_MODE=external
FLASHLY_PDF_EXTRACTION_PROVIDER=local
FLASHLY_OCR_PROVIDER=ocrspace
FLASHLY_OCR_API_URL=https://api.ocr.space/parse/image
FLASHLY_OCR_API_KEY=
FLASHLY_OCR_TIMEOUT_MS=20000

# AI
FLASHLY_GENERATION_MODE=external
FLASHLY_AI_PROVIDER=nvidia
FLASHLY_AI_API_KEY=
FLASHLY_AI_BASE_URL=https://integrate.api.nvidia.com/v1
FLASHLY_AI_MODEL=openai/gpt-oss-20b
FLASHLY_AI_REQUEST_TIMEOUT_MS=120000

# RevenueCat
FLASHLY_BILLING_MODE=revenuecat
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=revenuecat_project_id_optional
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro

# Monitoring
SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=flashly-staging-commit

# Security
FLASHLY_ALLOWED_ORIGINS=https://staging-app.example.com
FLASHLY_RATE_LIMIT_WINDOW_MS=60000
FLASHLY_RATE_LIMIT_MAX=120
FLASHLY_AUTH_RATE_LIMIT_MAX=30
FLASHLY_UPLOAD_RATE_LIMIT_MAX=20
FLASHLY_GENERATION_RATE_LIMIT_MAX=10

# Staging verification
FLASHLY_STAGING_BASE_URL=https://staging-api.example.com
FLASHLY_STAGING_TEST_TOKEN=
FLASHLY_STAGING_SECOND_USER_TOKEN=
# Recommended for long staging smoke runs: use active Clerk session ids so the smoke can mint fresh 60-second JWTs.
FLASHLY_STAGING_TEST_SESSION_ID=
FLASHLY_STAGING_SECOND_USER_SESSION_ID=
FLASHLY_STAGING_TEST_CLERK_USER_ID=optional_if_test_token_is_not_a_jwt
FLASHLY_STAGING_RATE_LIMIT_ATTEMPTS=150
